{
	"containerEnv": {
		"CCACHE_DIR": "/home/user/lab2/.ccache",
		"CORES_DIR": "/cores",
		"PREFIX": "${PREFIX:-~/.local}",
		"SHELL": "/bin/bash"
	},
	"customizations": {
		"vscode": {
			"extensions": [
				"llvm-vs-code-extensions.vscode-clangd",
				"ms-vscode.cmake-tools",
				"ms-vscode.makefile-tools",
				"vadimcn.vscode-lldb",
				"ms-azuretools.vscode-docker"
			],
			"settings": {
				"clangd.arguments": [
					"--background-index",
					"--compile-commands-dir=.vscode",
					"--clang-tidy",
					"--completion-style=detailed",
					"--header-insertion=never"
				],
				"clangd.path": "/usr/bin/clangd",
				"cmake.automaticReconfigure": false,
				"cmake.configureOnEdit": false,
				"cmake.configureOnOpen": false,
				"cmake.copyCompileCommands": "${workspaceFolder}/.vscode/compile_commands.json"
			}
		}
	},
	"forwardPorts": [8080],
	"image": "ghcr.io/userver-framework/ubuntu-22.04-userver-pg-dev:latest",
	"mounts": [],
	"onCreateCommand": "sudo git config --global --add safe.directory /home/user/lab2",
	"remoteUser": "user",
	"runArgs": ["--cap-add=SYS_PTRACE", "--security-opt", "seccomp=unconfined"],
	"workspaceFolder": "/home/user/lab2",
	"workspaceMount": "source=${localWorkspaceFolder},target=/home/user/lab2,type=bind"
}
